{
  "name": "hooxygen",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/inject-scripts.mjs",
    "preview": "vite preview",
    "cf:dev": "npm run build && wrangler pages dev dist/",
    "cf:deploy:mailer": "wrangler deploy --config workers/contact-mailer/wrangler.toml",
    "cf:deploy:pages": "npm run build && wrangler pages deploy dist/",
    "cf:deploy": "npm run cf:deploy:mailer && npm run cf:deploy:pages",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "i18next": "^25.2.1",
    "i18next-browser-languagedetector": "^8.0.5",
    "motion": "^12.7.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.55.0",
    "react-i18next": "^15.5.1",
    "react-router-dom": "^6.30.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250404.0",
    "@eslint/js": "^9.22.0",
    "@tailwindcss/vite": "^4.1.4",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "4.3.4",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.26.1",
    "vite": "5.4.21",
    "vite-plugin-ssg": "^0.1.0",
    "wrangler": "^4.82.1"
  }
}
